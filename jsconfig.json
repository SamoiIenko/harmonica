{
    "compilerOptions": {
        "strict": true,
        "baseUrl": "./src",
        "paths": {
            "@assets/*": [
            "assets/*"
            ],
            "@app/*": [
            "app/*"
            ],
            "@pages": [
            "pages"
            ],
            "@pages/*": [
            "pages/*"
            ],
            "@widgets/*": [
            "widgets/*"
            ],
            "@features/*": [
            "features/*"
